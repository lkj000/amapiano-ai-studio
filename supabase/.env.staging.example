# Staging environment configuration
# Copy to supabase/.env.staging (never commit with real values)
SUPABASE_URL=https://YOUR_STAGING_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your_staging_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_staging_service_role_key
LOVABLE_API_KEY=your_lovable_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key_optional
MODAL_API_URL=https://your-staging-modal-app.modal.run
TEMPORAL_NAMESPACE=your-temporal-namespace
TEMPORAL_API_KEY=your-temporal-api-key
ELEVENLABS_API_KEY=your_elevenlabs_api_key
DEPLOY_ENV=staging
